# Meeting Note configuration
# Copy this file to .env and fill in your values.
# Do not commit .env.

# OpenAI API Key (required for transcription)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter API Key (required for summaries and titles)
# Get your key at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
SUMMARY_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Application settings
APP_LANGUAGE=en
ONBOARDING_COMPLETED=false
APP_DATA_DIR=./data
RECORDINGS_DIR=./data/recordings
DATABASE_PATH=./data/database.db

# Audio settings
SAMPLE_RATE=16000
CHANNELS=1
AUDIO_DEVICE_INDEX=

# Transcription settings
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TRANSCRIPTION_LANGUAGE=
MIN_RECORDING_DURATION=5
SILENCE_THRESHOLD=500

# Auto-trigger settings
TRIGGER_MODE=notification
AUTO_TRIGGER_ENABLED=true
VAD_ENABLED=true
PROCESS_MONITOR_ENABLED=true

# VAD settings
VAD_AGGRESSIVENESS=2
VAD_SPEECH_THRESHOLD_SECONDS=10
VAD_SILENCE_THRESHOLD_SECONDS=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=./data/meeting_note.log

# Privacy and updates
# Anonymous analytics and crash reports stay off until the user opts in.
PRIVACY_CHOICE_COMPLETED=false
ANONYMOUS_ANALYTICS_ENABLED=false
CRASH_REPORTS_ENABLED=false
UPDATE_CHECKS_ENABLED=true
SENTRY_DSN=
